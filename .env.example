# Copier ce fichier en .env.local et renseigner les valeurs.

# Base de données PostgreSQL (Neon)
DATABASE_URL=

# Mot de passe d'accès à l'application
SITE_PASSWORD=

# Clés des services externes
APOLLO_API_KEY=
GROQ_API_KEY=
RESEND_API_KEY=
RESEND_FROM=

# Optionnel : signature et mentions légales personnalisées
SIGNATURE_HTML=
LEGAL_FOOTER=
LEGAL_FOOTER_HTML=
